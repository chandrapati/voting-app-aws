# Copy to terraform.tfvars and adjust as needed.
# cp terraform.tfvars.example terraform.tfvars

project_name            = "voting-app"
vpc_region              = "us-east-1"
vpc_availability_zones  = ["us-east-1a", "us-east-1b"]
aws_credentials_profile = "" # empty = default AWS CLI profile
ssh_public_key_file     = "voting-app-key.pub"
use_spot_instances      = false
instance_type           = "t3.micro"
db_instance_type        = "t3.small"
enable_vpc_flow_logs    = true
flow_logs_retention_days = 7
enable_traffic_generator = true
client_instance_type     = "t3.micro"
